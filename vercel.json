{
  "version": 2,
  "framework": "nextjs",
  "functions": {
    "app/api/check/route.ts": {
      "maxDuration": 15
    },
    "app/api/cron/watchlist-scan/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/digest-email/route.ts": {
      "maxDuration": 60
    },
    "app/api/watchlist-notifications/route.ts": {
      "maxDuration": 10
    },
    "app/api/badge/[domain]/route.ts": {
      "maxDuration": 10
    },
    "app/api/og/route.tsx": {
      "maxDuration": 10
    }
  },
  "crons": [
    {
      "path": "/api/cron/watchlist-scan",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/digest-email",
      "schedule": "0 9 * * 1"
    }
  ],
  "headers": [
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*\\.(?:css|js|mjs|ico|png|jpg|jpeg|gif|svg|webp|avif|woff2))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ]
    }
  ]
}
