# Public base URL used for canonical metadata and share links.
NEXT_PUBLIC_SITE_URL=https://security-header-checker.vercel.app

# Optional analytics providers.
# Plausible domain enables custom frontend events in addition to page views.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=security-header-checker.vercel.app
# Set to "true" to opt out of Vercel Analytics collection in self-hosted setups.
# NEXT_PUBLIC_VERCEL_ANALYTICS_DISABLED=false

# Optional Sentry monitoring.
# Client-side DSN (safe to expose publicly) for browser and edge error capture.
# NEXT_PUBLIC_SENTRY_DSN=https://<public-key>@o0.ingest.sentry.io/0
# Server-side DSN (used for API and server-rendering error capture).
# SENTRY_DSN=https://<public-key>@o0.ingest.sentry.io/0
# Optional sample-rate overrides (0.0 - 1.0).
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_ENVIRONMENT=production

# NextAuth configuration.
# Local dev: http://localhost:3000
# Production: https://<your-vercel-domain>
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# OAuth providers (configure at least one).
GITHUB_ID=your-github-oauth-app-client-id
GITHUB_SECRET=your-github-oauth-app-client-secret
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# API rate limiting (requests per minute).
# Unauthenticated requests are tracked by client IP.
API_RATE_LIMIT_ANON_PER_MINUTE=30
# Authenticated requests are tracked by user/session identity.
API_RATE_LIMIT_AUTH_PER_MINUTE=100
# API-key authenticated requests can use a higher limit than browser sessions.
API_RATE_LIMIT_API_KEY_PER_MINUTE=300

# Email notifications (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxx
# Use a verified sender in production. The default fallback uses onboarding@resend.dev.
RESEND_FROM_EMAIL=Security Header Checker <alerts@yourdomain.com>

# Scheduled watchlist scan cron security
# Set this in production and send as:
# - Authorization: Bearer <CRON_SECRET>
# or
# - x-cron-secret: <CRON_SECRET>
CRON_SECRET=replace-with-a-long-random-secret

# Optional cron tuning knobs
# CRON_ROUTE_RATE_LIMIT_PER_MINUTE=4
# CRON_WATCHLIST_SCAN_CONCURRENCY=3
# CRON_WATCHLIST_MAX_DOMAINS_PER_RUN=200
# CRON_WATCHLIST_MAX_EMAILS_PER_RUN=250

# Vercel cron schedule is configured in vercel.json:
# /api/cron/watchlist-scan -> */15 * * * *
